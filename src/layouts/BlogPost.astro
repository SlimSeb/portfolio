---
import BaseLayout from "./BaseLayout.astro";
import "../styles/prose.css";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}
const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout title={`${title} | slim.tf`} description={description}>
  <article class="sl-container" style="max-width:760px;padding-block:var(--sl-space-16)">
    <a href="/blog" style="color:var(--sl-accent-ink);font-size:var(--sl-text-sm);text-decoration:none">
      ← Back to blog
    </a>

    <header style="margin:var(--sl-space-6) 0 var(--sl-space-12)">
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:var(--sl-space-4)">
        {tags.map((tag) => <span class="sl-badge">{tag}</span>)}
      </div>
      <h1 style="font-size:var(--sl-text-h2);font-weight:var(--sl-weight-black);margin-bottom:var(--sl-space-3)">
        {title}
      </h1>
      <p style="color:var(--sl-text-secondary);font-size:var(--sl-text-lg);margin:0 0 var(--sl-space-4)">
        {description}
      </p>
      <time datetime={pubDate.toISOString()} style="color:var(--sl-text-muted);font-size:var(--sl-text-sm)">
        {fmt(pubDate)}
        {updatedDate && <span> · updated {fmt(updatedDate)}</span>}
      </time>
    </header>

    <div class="sl-prose">
      <slot />
    </div>
  </article>
</BaseLayout>
