---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Crow from "../components/Crow.astro";

interface Props {
  title: string;
  description?: string;
  /** Set false on the home page where the hero band sits behind the nav. */
  padForNav?: boolean;
  /** Open Graph type; blog posts pass "article". */
  type?: "website" | "article";
  /** Absolute path to a social preview image, e.g. "/og.png". */
  image?: string;
  /** Article metadata, only used when type is "article". */
  publishedTime?: Date;
  updatedTime?: Date;
}
const {
  title,
  description = "Portfolio and blog of Slimane Sébastien Fakani, a software developer in Lyon working with .NET, writing about software architecture, performance, and backend systems.",
  padForNav = true,
  type = "website",
  image = "/og.png",
  publishedTime,
  updatedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="slim.tf" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="slim.tf" />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {updatedTime && <meta property="article:modified_time" content={updatedTime.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="slim.tf" href="/rss.xml" />
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;700;800&family=Inter:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav />
    {
      padForNav ? (
        <main style="padding-top:var(--sl-nav-height)">
          <slot />
        </main>
      ) : (
        <main>
          <slot />
        </main>
      )
    }

    <footer class="sl-container" style="padding-block:var(--sl-space-12);border-top:1px solid var(--sl-border);margin-top:var(--sl-space-16);color:var(--sl-text-muted);font-size:var(--sl-text-sm);display:flex;justify-content:space-between;flex-wrap:wrap;gap:var(--sl-space-4)">
      <span style="display:inline-flex;align-items:center;gap:var(--sl-space-2)">
        <Crow class="sl-footer-crow" thick strokeWidth={15} aria-hidden="true" />
        © {new Date().getFullYear()} slim.tf
      </span>
      <span style="display:flex;gap:var(--sl-space-6)">
        <a href="/rss.xml" style="color:var(--sl-accent-ink)">RSS</a>
        <a href="https://github.com/SlimSeb" style="color:var(--sl-accent-ink)" target="_blank" rel="noopener noreferrer">GitHub</a>
      </span>
    </footer>
  </body>
</html>
