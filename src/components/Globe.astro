---
// Wireframe globe: a rotating teal sphere drawn on canvas, matching the
// hero grid's aesthetic. Zero framework, reduced-motion aware.
---

<div class="sl-globe">
  <canvas class="sl-globe-canvas" id="globeCanvas" role="img" aria-label="Rotating wireframe globe (drag to spin)"></canvas>
</div>

<script>
  import { LAND_RINGS } from "../data/land";

  const canvas = document.getElementById("globeCanvas") as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext("2d")!;
    const host = canvas.parentElement as HTMLElement;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    const TEAL = "63,169,161";
    const LAND = "44,138,131"; // deeper teal for the map layer + marker
    const MERIDIANS = 14;
    const PARALLELS = 7;
    const SEG = 40; // samples per line
    const AUTO_SPIN = reduce ? 0 : 0.0022; // idle rotation per frame
    const DRAG_TILT_MIN = -1.2;
    const DRAG_TILT_MAX = 1.2;
    const DEG = Math.PI / 180;

    // Approximate Lyon, France.
    const LYON = { lng: 4.83, lat: 45.76 };

    // High-resolution coastline outlines, each a closed loop of [lng, lat].
    // See src/data/land.ts for provenance (Natural Earth 1:110m).
    const CONTINENTS = LAND_RINGS;

    // Orientation, driven by auto-spin or dragging.
    let rot = 0; // longitude
    let tilt = 0.42; // lean the axis toward the viewer a touch
    let velRot = 0; // inertia after a throw
    let velTilt = 0;
    let dragging = false;
    let raf = 0;
    // "Fly to Lyon" focus animation + highlight window
    let focusAnim: {
      t0: number;
      dur: number;
      r0: number;
      r1: number;
      tl0: number;
      tl1: number;
    } | null = null;
    let holdUntil = 0; // pause auto-spin until this time
    let highlightUntil = 0; // emphasise the marker until this time
    const HIGHLIGHT_MS = 1000;

    const resize = () => {
      const w = host.clientWidth,
        h = host.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      render();
    };

    // Project a (latitude, longitude) point on the unit sphere to screen
    // space, returning x/y and a depth z in [-1, 1] (1 = nearest the viewer).
    const project = (
      theta: number,
      phi: number,
      cx: number,
      cy: number,
      r: number,
    ) => {
      const cT = Math.cos(theta);
      const x = cT * Math.sin(phi + rot);
      const y = Math.sin(theta);
      const z = cT * Math.cos(phi + rot);
      // tilt about the X axis so we look at the globe slightly from above
      const y2 = y * Math.cos(tilt) - z * Math.sin(tilt);
      const z2 = y * Math.sin(tilt) + z * Math.cos(tilt);
      return { px: cx + r * x, py: cy - r * y2, z: z2 };
    };

    const line = (pts: { px: number; py: number; z: number }[]) => {
      for (let i = 1; i < pts.length; i++) {
        const a = pts[i - 1],
          b = pts[i];
        const depth = (a.z + b.z) / 2; // -1 (back) .. 1 (front)
        const alpha = 0.05 + 0.33 * ((depth + 1) / 2);
        ctx.strokeStyle = `rgba(${TEAL},${alpha})`;
        ctx.lineWidth = depth > 0 ? 1.4 : 1;
        ctx.beginPath();
        ctx.moveTo(a.px, a.py);
        ctx.lineTo(b.px, b.py);
        ctx.stroke();
      }
    };

    const render = () => {
      const w = host.clientWidth,
        h = host.clientHeight;
      const cx = w / 2,
        cy = h / 2;
      const r = Math.min(w, h) * 0.4;

      ctx.clearRect(0, 0, w, h);

      // soft halo behind the sphere
      const halo = ctx.createRadialGradient(cx, cy, r * 0.2, cx, cy, r * 1.35);
      halo.addColorStop(0, `rgba(${TEAL},0.12)`);
      halo.addColorStop(1, `rgba(${TEAL},0)`);
      ctx.fillStyle = halo;
      ctx.beginPath();
      ctx.arc(cx, cy, r * 1.35, 0, Math.PI * 2);
      ctx.fill();

      // meridians (lines of longitude)
      for (let m = 0; m < MERIDIANS; m++) {
        const phi = (m / MERIDIANS) * Math.PI * 2;
        const pts = [];
        for (let i = 0; i <= SEG; i++) {
          const theta = -Math.PI / 2 + (i / SEG) * Math.PI;
          pts.push(project(theta, phi, cx, cy, r));
        }
        line(pts);
      }

      // parallels (lines of latitude)
      for (let p = 1; p <= PARALLELS; p++) {
        const theta = -Math.PI / 2 + (p / (PARALLELS + 1)) * Math.PI;
        const pts = [];
        for (let i = 0; i <= SEG; i++) {
          const phi = (i / SEG) * Math.PI * 2;
          pts.push(project(theta, phi, cx, cy, r));
        }
        line(pts);
      }

      // low-poly land masses, projected onto the surface (front side only)
      for (const poly of CONTINENTS) {
        const pr = poly.map(([lng, lat]) =>
          project(lat * DEG, lng * DEG, cx, cy, r),
        );
        // faint fill from the front-facing vertices for a low-poly look
        const front = pr.filter((p) => p.z > 0);
        if (front.length >= 3) {
          ctx.beginPath();
          ctx.moveTo(front[0].px, front[0].py);
          for (let i = 1; i < front.length; i++) ctx.lineTo(front[i].px, front[i].py);
          ctx.closePath();
          ctx.fillStyle = `rgba(${LAND},0.08)`;
          ctx.fill();
        }
        // crisp edges, drawn only where both ends face the viewer
        ctx.lineWidth = 1.5;
        for (let i = 0; i < pr.length; i++) {
          const a = pr[i],
            b = pr[(i + 1) % pr.length];
          if (a.z <= 0 || b.z <= 0) continue;
          ctx.strokeStyle = `rgba(${LAND},${0.3 + 0.45 * Math.min(a.z, b.z)})`;
          ctx.beginPath();
          ctx.moveTo(a.px, a.py);
          ctx.lineTo(b.px, b.py);
          ctx.stroke();
        }
      }

      // Lyon marker
      const ly = project(LYON.lat * DEG, LYON.lng * DEG, cx, cy, r);
      if (ly.z > 0) {
        const depth = ly.z; // 0..1, larger = nearer
        const now = performance.now();
        // 1 right after a "fly to Lyon" click, easing back to 0
        const hi = Math.max(0, Math.min(1, (highlightUntil - now) / HIGHLIGHT_MS));
        const pulse = reduce ? 0.5 : 0.5 + 0.5 * Math.sin(now * 0.004);
        const scale = 0.6 + depth * 0.4;
        // extra expanding rings while highlighted
        if (hi > 0 && !reduce) {
          for (let k = 0; k < 2; k++) {
            const rp = (now * 0.0016 + k * 0.5) % 1;
            ctx.beginPath();
            ctx.arc(ly.px, ly.py, (5 + rp * 24) * scale, 0, Math.PI * 2);
            ctx.strokeStyle = `rgba(${LAND},${0.55 * hi * (1 - rp) * depth})`;
            ctx.lineWidth = 1.5;
            ctx.stroke();
          }
        }
        // base pulse ring
        ctx.beginPath();
        ctx.arc(ly.px, ly.py, (4 + pulse * 7) * scale, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(${LAND},${0.35 * (1 - pulse) * depth})`;
        ctx.lineWidth = 1.5;
        ctx.stroke();
        // solid dot, swells while highlighted
        ctx.beginPath();
        ctx.arc(ly.px, ly.py, (3.2 + hi * 2) * (0.7 + depth * 0.3), 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${LAND},${0.85 * depth + 0.15})`;
        ctx.fill();
        // label
        ctx.font =
          "600 12px ui-sans-serif, system-ui, -apple-system, sans-serif";
        ctx.textBaseline = "middle";
        ctx.fillStyle = `rgba(18,63,59,${0.85 * depth})`;
        ctx.fillText("Lyon", ly.px + 9, ly.py - 0.5);
      }
    };

    const tick = () => {
      const now = performance.now();
      if (focusAnim) {
        // ease toward the orientation that puts Lyon front-and-centre
        const p = Math.min(1, (now - focusAnim.t0) / focusAnim.dur);
        const e = p < 0.5 ? 4 * p * p * p : 1 - Math.pow(-2 * p + 2, 3) / 2;
        rot = focusAnim.r0 + (focusAnim.r1 - focusAnim.r0) * e;
        tilt = focusAnim.tl0 + (focusAnim.tl1 - focusAnim.tl0) * e;
        if (p >= 1) focusAnim = null;
      } else if (!dragging) {
        const spin = now < holdUntil ? 0 : AUTO_SPIN;
        rot += spin + velRot;
        tilt = Math.max(DRAG_TILT_MIN, Math.min(DRAG_TILT_MAX, tilt + velTilt));
        velRot *= 0.92; // inertia decay
        velTilt *= 0.92;
        if (Math.abs(velRot) < 0.00005) velRot = 0;
        if (Math.abs(velTilt) < 0.00005) velTilt = 0;
      }
      render();
      // Keep animating while spinning, throwing, dragging, flying to Lyon, or
      // showing the highlight; otherwise settle (lets reduced-motion idle).
      if (
        dragging ||
        focusAnim ||
        AUTO_SPIN !== 0 ||
        velRot !== 0 ||
        velTilt !== 0 ||
        now < highlightUntil
      ) {
        raf = requestAnimationFrame(tick);
      } else {
        raf = 0;
      }
    };

    const wake = () => {
      if (!raf) raf = requestAnimationFrame(tick);
    };

    // --- drag to spin ---
    let lastX = 0,
      lastY = 0;

    const onDown = (e: PointerEvent) => {
      dragging = true;
      velRot = 0;
      velTilt = 0;
      lastX = e.clientX;
      lastY = e.clientY;
      canvas.setPointerCapture(e.pointerId);
      canvas.classList.add("is-dragging");
      wake();
    };

    const onMove = (e: PointerEvent) => {
      if (!dragging) return;
      const dx = e.clientX - lastX;
      const dy = e.clientY - lastY;
      lastX = e.clientX;
      lastY = e.clientY;
      const dRot = dx * 0.01;
      const dTilt = dy * 0.01;
      rot += dRot;
      tilt = Math.max(DRAG_TILT_MIN, Math.min(DRAG_TILT_MAX, tilt + dTilt));
      velRot = dRot; // carried into inertia on release
      velTilt = dTilt;
      render();
    };

    const onUp = (e: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      canvas.classList.remove("is-dragging");
      try {
        canvas.releasePointerCapture(e.pointerId);
      } catch {}
      wake();
    };

    canvas.addEventListener("pointerdown", onDown);
    canvas.addEventListener("pointermove", onMove);
    canvas.addEventListener("pointerup", onUp);
    canvas.addEventListener("pointercancel", onUp);
    window.addEventListener("resize", resize);

    // --- "fly to Lyon" focus, triggered from anywhere on the page ---
    const focusLyon = () => {
      const now = performance.now();
      velRot = 0;
      velTilt = 0;
      // Lyon faces the viewer when rot = -lng and tilt = lat (see project()).
      const targetTilt = LYON.lat * DEG;
      const desired = -LYON.lng * DEG;
      let d = (desired - rot) % (Math.PI * 2);
      if (d > Math.PI) d -= Math.PI * 2;
      if (d < -Math.PI) d += Math.PI * 2;
      focusAnim = {
        t0: now,
        dur: reduce ? 1 : 1100,
        r0: rot,
        r1: rot + d,
        tl0: tilt,
        tl1: targetTilt,
      };
      const settle = (reduce ? 0 : 1100) + HIGHLIGHT_MS;
      holdUntil = now + settle; // let it linger before auto-spin resumes
      highlightUntil = reduce ? 0 : now + settle;
      wake();
    };

    document.querySelectorAll<HTMLElement>("[data-globe-focus]").forEach((el) =>
      el.addEventListener("click", (e) => {
        e.preventDefault();
        focusLyon();
      }),
    );

    resize();
    wake();
  }
</script>
