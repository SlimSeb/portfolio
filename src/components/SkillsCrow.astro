---
// Skills scene: the crow model sits centered between two parenthesis-shaped
// selectors, like ( crow ). Each paren is drawn with thick CSS borders and
// split into three clickable segments, one per skill; picking one reveals
// its card (with a link) beside it and turns the crow toward it. Without JS
// or WebGL the cards render as a plain stacked list.
type Skill = { title: string; body: string; href: string; cta: string };

const SKILLS: Skill[] = [
  {
    title: ".NET & C#",
    body: "My daily drivers: modern C#, ASP.NET, and the tooling around them.",
    href: "/cv",
    cta: "See my CV",
  },
  {
    title: "Software architecture",
    body: "Plugin systems, dependency injection, and designs that stay easy to change.",
    href: "#about",
    cta: "More about me",
  },
  {
    title: "Data & observability",
    body: "EF Core for persistence, OpenTelemetry for seeing what actually happens.",
    href: "https://github.com/SlimSeb",
    cta: "My GitHub",
  },
  {
    title: "Performance",
    body: "Profiling, allocations, and the low-level details that make code fast.",
    href: "/blog",
    cta: "Read the blog",
  },
  {
    title: "CI/CD",
    body: "Pipelines that build, test, and ship without ceremony.",
    href: "https://www.nuget.org/profiles/Slimf",
    cta: "Packages on NuGet",
  },
  {
    title: "Side projects",
    body: "Elsa-Mina, Simplex, and a few NuGet packages I maintain.",
    href: "#work",
    cta: "Selected work",
  },
];

const left = SKILLS.slice(0, 3);
const right = SKILLS.slice(3);
---

<div class="sl-crow-scene" id="crowScene">
  <div class="sl-crow-stage">
    <div class="sl-crow-cards sl-crow-cards-left">
      {
        left.map((s, r) => (
          <article class="sl-card sl-crow-card" id={`crow-card-${r}`}>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            <a class="sl-btn sl-btn-secondary" href={s.href}>
              {s.cta}
            </a>
          </article>
        ))
      }
    </div>
    <div class="sl-crow-side sl-crow-side-left">
      {
        left.map((s, r) => (
          <button type="button" class="sl-crow-seg" data-row={r} aria-expanded="false" aria-controls={`crow-card-${r}`}>
            {s.title}
          </button>
        ))
      }
    </div>
    <canvas
      class="sl-crow-canvas"
      id="crowCanvas"
      role="img"
      aria-label="3D model of a crow flapping its wings; pick a skill to make it turn toward the matching card, or drag to spin it."
    ></canvas>
    <div class="sl-crow-side sl-crow-side-right">
      {
        right.map((s, r) => (
          <button type="button" class="sl-crow-seg" data-row={r} aria-expanded="false" aria-controls={`crow-card-${r + 3}`}>
            {s.title}
          </button>
        ))
      }
    </div>
    <div class="sl-crow-cards sl-crow-cards-right">
      {
        right.map((s, r) => (
          <article class="sl-card sl-crow-card" id={`crow-card-${r + 3}`}>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            <a class="sl-btn sl-btn-secondary" href={s.href}>
              {s.cta}
            </a>
          </article>
        ))
      }
    </div>
    <span class="sl-crow-hint" id="crowHint" aria-hidden="true">pick a skill · drag to spin</span>
  </div>
</div>

<script>
  const MODEL_URL = "/models/crow-spread.glb";
  const BASE_YAW = -0.45; // resting three-quarter view
  const TILT_MAX = 0.6;

  const host = document.getElementById("crowScene");
  const canvas = document.getElementById("crowCanvas") as HTMLCanvasElement | null;
  const hint = document.getElementById("crowHint");

  async function init(host: HTMLElement, canvas: HTMLCanvasElement) {
    // three.js is heavy, so it is code-split and only fetched once the
    // section is about to scroll into view.
    const [THREE, { GLTFLoader }, { RoomEnvironment }] = await Promise.all([
      import("three"),
      import("three/addons/loaders/GLTFLoader.js"),
      import("three/addons/environments/RoomEnvironment.js"),
    ]);

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(34, 1, 0.05, 20);

    // Lighting reads from the --sl-model-* tokens so the theme toggle
    // relights the crow; the neutral room env gives the feathers their sheen.
    const key = new THREE.DirectionalLight(0xffffff, 2.0);
    key.position.set(1.6, 2.4, 2.2);
    const rim = new THREE.DirectionalLight(0xffffff, 2.6);
    rim.position.set(-2.2, 1.4, -2.4);
    const fill = new THREE.HemisphereLight(0xffffff, 0x000000, 1.0);
    scene.add(key, rim, fill);
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

    const readTheme = () => {
      const s = getComputedStyle(document.documentElement);
      const rgb = (name: string) => new THREE.Color(`rgb(${s.getPropertyValue(name).trim()})`);
      key.color = rgb("--sl-model-key-rgb");
      rim.color = rgb("--sl-model-rim-rgb");
      fill.color = rgb("--sl-model-fill-rgb");
      fill.groundColor = fill.color.clone().multiplyScalar(0.35);
      scene.environmentIntensity = parseFloat(s.getPropertyValue("--sl-model-env")) || 1;
    };
    readTheme();

    const gltf = await new GLTFLoader().loadAsync(MODEL_URL);
    const rig = new THREE.Group();

    // Center the wrapper (not the animated node, whose transform the mixer
    // owns) and normalize scale so framing is independent of model units.
    const bbox = new THREE.Box3().setFromObject(gltf.scene);
    const size = bbox.getSize(new THREE.Vector3());
    const center = bbox.getCenter(new THREE.Vector3());
    gltf.scene.position.sub(center);
    const maxDim = Math.max(size.x, size.y, size.z);
    rig.scale.setScalar(1 / maxDim);
    rig.add(gltf.scene);
    scene.add(rig);

    // The flap plays on its own clock; ping-pong keeps it seamless even if
    // the clip's last frame does not match its first.
    const mixer = new THREE.AnimationMixer(gltf.scene);
    const clip = gltf.animations[0];
    if (clip) {
      const action = mixer.clipAction(clip);
      action.setLoop(THREE.LoopPingPong, Infinity);
      action.play();
      if (reduce) {
        // Reduced motion: no flapping, hold a static wings-spread pose.
        mixer.setTime(clip.duration);
      } else {
        action.timeScale = 0.75; // flap at 3/4 of the authored speed
      }
    }

    // The head sits on whichever horizontal axis is not the wingspan, so the
    // yaw that faces a given direction depends on the export orientation.
    const yawOffset = size.x >= size.z ? 0 : -Math.PI / 2;

    // Rotation state: yaw/tilt ease toward their targets in the render loop.
    // Dragging moves value and target together so the crow tracks the
    // pointer 1:1; selecting a segment only moves the target, so the crow
    // swings over smoothly.
    let yaw = BASE_YAW;
    let tilt = 0;
    let targetYaw = BASE_YAW;
    let targetTilt = 0;
    let velYaw = 0;
    let velTilt = 0;
    let dragging = false;
    let lastX = 0;
    let lastY = 0;
    const clampTilt = (t: number) => Math.max(-TILT_MAX, Math.min(TILT_MAX, t));

    // dt defaults to Infinity so on-demand frames (resize, theme change,
    // reduced motion) snap the eased rotation straight to its target.
    const frame = (dt = Infinity) => {
      const k = 1 - Math.exp(-5 * dt);
      yaw += (targetYaw - yaw) * k;
      tilt += (targetTilt - tilt) * k;
      rig.rotation.y = yaw;
      rig.rotation.x = tilt;
      renderer.render(scene, camera);
    };

    // Where the crow looks when segment i is selected: a point out to that
    // side, raised for the top row and lowered for the bottom one.
    const facing = (i: number) => {
      const side = i < 3 ? -1 : 1;
      const row = i % 3;
      const px = side * 1.15;
      const py = 0.45 - row * 0.45;
      const pz = 0.9;
      return {
        yaw: Math.atan2(px, pz) + yawOffset,
        tilt: clampTilt(-Math.atan2(py, Math.hypot(px, pz))),
      };
    };

    const segs = [...host.querySelectorAll<HTMLButtonElement>(".sl-crow-seg")];
    const cards = [...host.querySelectorAll<HTMLElement>(".sl-crow-card")];
    let selected = -1;

    const select = (i: number) => {
      selected = selected === i ? -1 : i; // click again to close
      segs.forEach((b, j) => {
        b.classList.toggle("is-on", j === selected);
        b.setAttribute("aria-expanded", String(j === selected));
      });
      cards.forEach((c, j) => c.classList.toggle("is-on", j === selected));
      hint?.classList.add("is-hidden");
      const t = selected === -1 ? { yaw: BASE_YAW, tilt: 0 } : facing(selected);
      targetYaw = t.yaw;
      targetTilt = t.tilt;
      velYaw = 0;
      velTilt = 0;
      // Unwind full turns left over from dragging so the crow takes the
      // short way around instead of spinning back through them.
      let d = (yaw - targetYaw) % (Math.PI * 2);
      if (d > Math.PI) d -= Math.PI * 2;
      if (d < -Math.PI) d += Math.PI * 2;
      yaw = targetYaw + d;
      if (reduce) frame(); // no loop running: snap to the new pose now
    };
    segs.forEach((b, i) => b.addEventListener("click", () => select(i)));
    host.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && selected !== -1) select(selected);
    });

    // Drag to spin: 0.01 rad per px, inertia on release (applied in the
    // render loop), vertical drag tilts with a clamp.
    canvas.addEventListener("pointerdown", (e) => {
      dragging = true;
      velYaw = 0;
      velTilt = 0;
      lastX = e.clientX;
      lastY = e.clientY;
      canvas.setPointerCapture(e.pointerId);
      canvas.classList.add("is-dragging");
    });
    canvas.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const dYaw = (e.clientX - lastX) * 0.01;
      const dTilt = (e.clientY - lastY) * 0.01;
      lastX = e.clientX;
      lastY = e.clientY;
      yaw += dYaw;
      targetYaw += dYaw;
      tilt = clampTilt(tilt + dTilt);
      targetTilt = clampTilt(targetTilt + dTilt);
      velYaw = dYaw; // carried into inertia on release
      velTilt = dTilt;
      if (reduce) frame(); // no loop running: render the drag now
    });
    const endDrag = (e: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      canvas.classList.remove("is-dragging");
      try {
        canvas.releasePointerCapture(e.pointerId);
      } catch {}
    };
    canvas.addEventListener("pointerup", endDrag);
    canvas.addEventListener("pointercancel", endDrag);

    const fitCamera = () => {
      const w = Math.max(1, canvas.clientWidth);
      const h = Math.max(1, canvas.clientHeight);
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      // Fit the (normalized) model into the canvas on both axes. Smaller =
      // the crow fills more of the frame, so the stage reads less empty.
      const halfFov = THREE.MathUtils.degToRad(camera.fov) / 2;
      const halfSize = 0.42;
      const dist = Math.max(halfSize / Math.tan(halfFov), halfSize / (Math.tan(halfFov) * camera.aspect * 0.95));
      camera.position.set(0, 0.1, dist);
      camera.lookAt(0, 0, 0);
      camera.updateProjectionMatrix();
    };

    // The flap always plays, so render on a rAF loop, but only while the
    // scene is on screen. Reduced motion renders single frames on demand.
    let lastTime = 0;
    let raf = 0;
    const loop = () => {
      raf = requestAnimationFrame(loop);
      const now = performance.now();
      const dt = Math.min((now - lastTime) / 1000, 0.1);
      lastTime = now;
      mixer.update(dt);
      if (!dragging) {
        yaw += velYaw;
        targetYaw += velYaw;
        tilt = clampTilt(tilt + velTilt);
        targetTilt = clampTilt(targetTilt + velTilt);
        velYaw *= 0.92; // inertia decay
        velTilt *= 0.92;
        if (Math.abs(velYaw) < 0.00005) velYaw = 0;
        if (Math.abs(velTilt) < 0.00005) velTilt = 0;
      }
      frame(dt);
    };
    const vis = new IntersectionObserver((entries) => {
      const seen = entries.some((e) => e.isIntersecting);
      if (reduce) {
        if (seen) frame();
      } else if (seen && !raf) {
        lastTime = performance.now(); // drop the time spent off screen
        loop();
      } else if (!seen && raf) {
        cancelAnimationFrame(raf);
        raf = 0;
      }
    });
    vis.observe(canvas);

    new ResizeObserver(() => {
      fitCamera();
      if (!raf) frame();
    }).observe(canvas);
    new MutationObserver(() => {
      readTheme();
      if (!raf) frame();
    }).observe(document.documentElement, { attributeFilter: ["data-theme"] });

    fitCamera();
    frame();
  }

  if (host && canvas) {
    const boot = () => {
      host.classList.add("sl-crow-ready");
      init(host, canvas).catch((err) => {
        // No WebGL or the model failed to load: back to the static card list.
        console.error("crow scene failed, falling back to static cards", err);
        host.classList.remove("sl-crow-ready");
      });
    };
    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect();
          boot();
        }
      },
      { rootMargin: "600px 0px" },
    );
    io.observe(host);
  }
</script>
