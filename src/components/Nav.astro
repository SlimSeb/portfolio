---
import Crow from "./Crow.astro";

const links = [
  { href: "/#work", label: "Work" },
  { href: "/#stack", label: "Stack" },
  { href: "/#blog", label: "Blog" },
  { href: "/#about", label: "About" },
];
---

<div class="sl-nav-wrap">
  <nav class="sl-nav" aria-label="Primary">
    <!-- <Crow class="sl-nav-crow" thick strokeWidth={10} aria-hidden="true" /> -->
    <a class="sl-nav-brand" href="/">slim.tf</a>
    <div class="sl-nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
    <div class="sl-nav-actions">
      <button class="sl-theme-toggle" id="themeToggle" type="button" aria-label="Switch between light and dark theme">
        <svg class="sl-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg class="sl-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
      </button>
      <a class="sl-btn sl-btn-primary" href="/#contact">Get in touch</a>
    </div>
  </nav>
</div>

<script>
  const toggle = document.getElementById("themeToggle");
  toggle?.addEventListener("click", () => {
    const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem("sl-theme", next);
    } catch {
      /* private mode: theme still flips for this page view */
    }
  });
</script>
