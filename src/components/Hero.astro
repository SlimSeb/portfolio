---
interface Props {
  eyebrow?: string;
  title?: string;
  accent?: string;
  subtitle?: string;
}
import Crow from "./Crow.astro";

const {
  eyebrow = "Designer & developer",
  title = "I build things",
  accent = "on the web",
  subtitle = "Portfolio and notes on design systems, front-end engineering, and the occasional side quest.",
} = Astro.props;
---

<div class="sl-hero">
  <canvas class="sl-hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
  <Crow class="sl-hero-crow" aria-hidden="true" />
  <div class="sl-hero-inner">
    <span class="sl-badge">{eyebrow}</span>
    <h1>{title}<br /><span class="sl-accent-text">{accent}</span></h1>
    <p>{subtitle}</p>
    <div class="sl-hero-cta">
      <a class="sl-btn sl-btn-primary" href="/#work">View work</a>
      <a class="sl-btn sl-btn-secondary" href="/blog">Read the blog</a>
    </div>
  </div>
</div>

<script>
  const canvas = document.getElementById("heroCanvas") as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext("2d")!;
    const host = canvas.parentElement as HTMLElement;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let t = 0;

    // Colors come from the --sl-* tokens so the theme toggle restyles the
    // canvas; RGB triplets let the script apply its own alpha.
    let grad1 = "", grad2 = "", lineRGB = "", horizonRGB = "";
    const readTheme = () => {
      const s = getComputedStyle(document.documentElement);
      grad1 = s.getPropertyValue("--sl-hero-grad-1").trim();
      grad2 = s.getPropertyValue("--sl-hero-grad-2").trim();
      lineRGB = s.getPropertyValue("--sl-canvas-accent-rgb").trim();
      horizonRGB = s.getPropertyValue("--sl-canvas-deep-rgb").trim();
    };
    readTheme();

    const resize = () => {
      const w = host.clientWidth,
        h = host.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener("resize", resize);

    const frame = () => {
      const w = host.clientWidth,
        h = host.clientHeight;
      const horizon = h * 0.42,
        cx = w / 2;
      ctx.clearRect(0, 0, w, h);

      const bg = ctx.createLinearGradient(0, 0, 0, h);
      bg.addColorStop(0, grad1);
      bg.addColorStop(1, grad2);
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, w, h);

      ctx.lineWidth = 1.5;
      const n = 16;
      for (let i = -n; i <= n; i++) {
        const fx = i / n;
        ctx.beginPath();
        ctx.moveTo(cx + fx * 40, horizon);
        ctx.lineTo(cx + fx * w * 1.6, h);
        ctx.strokeStyle = `rgba(${lineRGB},${0.12 + 0.3 * (1 - Math.abs(fx))})`;
        ctx.stroke();
      }

      const move = reduce ? 0 : (t * 0.00005) % 1;
      for (let r = 0; r < 22; r++) {
        const p = (r / 22 + move) % 1,
          ease = p * p;
        const y = horizon + ease * (h - horizon);
        const spread = 40 + ease * (w * 1.6 - 40);
        ctx.beginPath();
        ctx.moveTo(cx - spread, y);
        ctx.lineTo(cx + spread, y);
        ctx.strokeStyle = `rgba(${lineRGB},${0.08 + 0.34 * ease})`;
        ctx.stroke();
      }

      ctx.fillStyle = `rgba(${horizonRGB},0.45)`;
      ctx.fillRect(0, horizon - 0.5, w, 1);

      // Fade the grid out toward the side/bottom edges so lines dissolve
      // into the backdrop instead of clipping hard at the canvas boundary
      // (the band behind uses the same gradient, so erasing blends clean).
      const fadeX = Math.min(140, w * 0.12);
      const fadeY = Math.min(110, h * 0.18);
      ctx.globalCompositeOperation = "destination-out";
      const fades: [number, number, number, number, number, number, number, number][] = [
        [0, 0, fadeX, 0, 0, 0, fadeX, h], // left
        [w, 0, w - fadeX, 0, w - fadeX, 0, fadeX, h], // right
        [0, h, 0, h - fadeY, 0, h - fadeY, w, fadeY], // bottom
      ];
      for (const [gx0, gy0, gx1, gy1, rx, ry, rw, rh] of fades) {
        const g = ctx.createLinearGradient(gx0, gy0, gx1, gy1);
        g.addColorStop(0, "rgba(0,0,0,1)");
        g.addColorStop(1, "rgba(0,0,0,0)");
        ctx.fillStyle = g;
        ctx.fillRect(rx, ry, rw, rh);
      }
      ctx.globalCompositeOperation = "source-over";

      t += 16;
      if (!reduce) requestAnimationFrame(frame);
    };
    frame();

    new MutationObserver(() => {
      readTheme();
      // with reduced motion there is no RAF loop, so repaint once
      if (reduce) frame();
    }).observe(document.documentElement, { attributeFilter: ["data-theme"] });
  }
</script>
