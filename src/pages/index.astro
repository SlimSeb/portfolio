---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Card from "../components/Card.astro";
import Globe from "../components/Globe.astro";
import SkillsCrow from "../components/SkillsCrow.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Slimane Fakani",
  url: new URL("/", Astro.site).href,
  jobTitle: "Software Developer",
  address: { "@type": "PostalAddress", addressLocality: "Lyon", addressCountry: "FR" },
  sameAs: ["https://github.com/SlimSeb"],
  knowsAbout: [".NET", "C#", "Software Architecture", "Backend Development", "CI/CD"],
});
---

<BaseLayout title="slim.tf: portfolio & blog" padForNav={false}>
  <script type="application/ld+json" slot="head" is:inline set:html={structuredData} />
  <header class="sl-band" id="top">
    <Hero />
  </header>

  <!-- Work -->
  <section class="sl-container sl-section sl-reveal" id="work">
    <span class="sl-eyebrow">Selected work</span>
    <h2>Things I've built</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:var(--sl-space-6)">
      <Card title="Design system" icon="◆">
        A teal, token-driven component library powering this very site.
      </Card>
      <Card title="Simplex" icon="✦">
        A side project of mine, live at{" "}
        <a class="sl-accent-text" href="https://simplex.slim.tf">simplex.slim.tf</a>.
      </Card>
      <Card title="Open source" icon="❖">
        A handful of NuGet packages I maintain, over on{" "}
        <a class="sl-accent-text" href="https://www.nuget.org/profiles/Slimf">my NuGet profile</a>.
      </Card>
    </div>
  </section>

  <!-- Stack -->
  <section class="sl-section-tint sl-reveal" id="stack">
    <div class="sl-container sl-section">
      <span class="sl-eyebrow">Stack</span>
      <h2>What I work with</h2>
      <p style="max-width:64ch;color:var(--sl-text-secondary);font-size:var(--sl-text-lg)">
        The tools and ideas I reach for most. Pick a skill, and the crow will point you to it.
      </p>
      <SkillsCrow />
    </div>
  </section>

  <!-- Latest writing -->
  <section class="sl-section-tint sl-reveal" id="blog">
    <div class="sl-container sl-section">
      <span class="sl-eyebrow">From the blog</span>
      <h2>Latest writing</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:var(--sl-space-6)">
        {
          posts.map((post) => (
            <PostCard
              href={`/blog/${post.id}/`}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
            />
          ))
        }
      </div>
      <div style="margin-top:var(--sl-space-8)">
        <a class="sl-btn sl-btn-secondary" href="/blog">All posts</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="sl-container sl-section sl-reveal" id="about">
    <span class="sl-eyebrow">About</span>
    <h2>A little about me</h2>
    <div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,400px);gap:var(--sl-space-8);align-items:start" class="sl-about-grid">
    <div style="max-width:64ch;color:var(--sl-text-secondary);font-size:var(--sl-text-lg);display:flex;flex-direction:column;gap:var(--sl-space-4)">
      <p>
        I'm a software developer <button type="button" class="sl-globe-focus" data-globe-focus>based in Lyon</button>,
        currently working on industrial test automation software. I mostly work
        with <span class="sl-accent-text">.NET</span>,
        and I enjoy thinking about how to structure systems so they stay reliable
        and easy to maintain. I also have a strong mathematical background that
        shapes how I approach problems.
      </p>
      <p>
        In my free time, I develop <strong style="color:var(--sl-text-primary)">Elsa-Mina</strong>,
        a .NET Pokémon Showdown bot framework built around dependency injection
        and a plugin-based design, backed by EF Core and OpenTelemetry for
        observability. I also maintain a few open-source NuGet packages.
      </p>
      <p style="margin-bottom:var(--sl-space-1)">My main interests include:</p>
      <div style="display:flex;flex-wrap:wrap;gap:var(--sl-space-2)">
        <span class="sl-badge">Backend &amp; Systems Programming</span>
        <span class="sl-badge">Software Architecture</span>
        <span class="sl-badge">Performance Optimization</span>
        <span class="sl-badge">CI/CD</span>
      </div>
      <p>
        I'm also genuinely interested in AI, not just using it but understanding
        how it works and building thoughtful workflows around it, while keeping a
        critical eye and staying grounded in the fundamentals.
      </p>
      <p>
        I try to keep my code simple and efficient, and I like digging into the
        low-level details to understand how things work and make them a bit faster.
      </p>
    </div>
      <div>
        <Globe />
      </div>
    </div>
    <div style="margin-top:var(--sl-space-6);display:flex;gap:var(--sl-space-3);flex-wrap:wrap" id="contact">
      <a class="sl-btn sl-btn-primary" href="mailto:slimane.fakani.dev@gmail.com">Get in touch</a>
      <a class="sl-btn sl-btn-secondary" href="/cv">View my CV</a>
    </div>
  </section>
</BaseLayout>

<script>
  // Flag JS so the reveal's hidden state only applies when we can reveal it.
  document.documentElement.classList.add("sl-js");

  const reveals = document.querySelectorAll<HTMLElement>(".sl-reveal");
  const observer = new IntersectionObserver(
    (entries, obs) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          obs.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.075, rootMargin: "0px 0px -20% 0px" },
  );
  reveals.forEach((el) => observer.observe(el));
</script>
